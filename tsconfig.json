{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
     "outDir": "dist",
    "rootDir": ".",
    "strict": false,
      // "noEmitOnError": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
    },
   "include": ["./*.ts", "./**/*.ts"],  // ← Add this
  "exclude": ["node_modules", "dist"]
}
