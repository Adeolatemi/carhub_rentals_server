
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String  
  phone     String? 
  company   String? 
  isActive  Boolean  @default(true)

  kycStatus String?
  kycFile   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings       CarBooking[]
  auditLogs      AuditLog[]      @relation("UserAuditLogs")
  partnerDetails PartnerDetails?
  vehicles       Vehicle[]
  subscriptions  Subscription[]
  kycHistory     KycHistory[]
  orders         Order[]

}

model KycHistory {
  id        String   @id @default(uuid())
  userId    String
  filename  String
  status    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model VehicleCategory {
  id       String    @id @default(cuid())
  name     String    @unique
  vehicles Vehicle[]
}

model Vehicle {
  id          String           @id @default(cuid())
  title       String
  description String?
  dailyRate   Float
  available   Boolean          @default(true)
  imageUrl    String?

  category    VehicleCategory? @relation(fields: [categoryId], references: [id])
  categoryId  String?

  owner       User?            @relation(fields: [ownerId], references: [id])
  ownerId     String?

  features    VehicleFeature[]
  bookings    CarBooking[]
  orders      Order[]

  createdAt   DateTime         @default(now())
}

model CarBooking {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id])
  vehicleId       String?
  fullName        String
  phone           String
  email           String
  pickupLocation  String
  dropoffLocation String
  startDate       DateTime
  endDate         DateTime
  totalAmount     Float
  status          String   @default("PENDING")
  adminNote       String?
  canceledReason  String?
  createdAt       DateTime @default(now())
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  vehicleId       String?
  status          String   @default("PENDING")
  total           Float
  fullName        String?
  phone           String?
  email           String?
  carType         String?
  serviceType     String?
  driver          String?
  passengers      Int?
  requests        String?
  pickupLocation  String?
  dropoffLocation String?
  pickupDate      DateTime?
  dropoffDate     DateTime?
  pickupTime      String?
  dropoffTime     String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id])
  attachments     OrderAttachment[]
  transactions    Transaction[]

  @@map("orders")
}

model OrderAttachment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  path      String
  type      String?
  createdAt DateTime @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  provider    String
  providerRef String?  @unique
  amount      Float
  createdAt   DateTime @default(now())
}

model Feature {
  id       String           @id @default(cuid())
  name     String           @unique
  desc     String?

  vehicles VehicleFeature[]
}

model VehicleFeature {
  id        String  @id @default(cuid())

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  vehicleId String

  feature   Feature @relation(fields: [featureId], references: [id])
  featureId String

  @@unique([vehicleId, featureId])
}

model AuditLog {
  id        String   @id @default(cuid())

  actorId   String?
  actor     User?    @relation("UserAuditLogs", fields: [actorId], references: [id])

  action    String
  meta      String?

  createdAt DateTime @default(now())
}

model PartnerDetails {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  company   String?
  phone     String?
  cacNumber String?
  fleetSize String?
  address   String?
  createdAt DateTime @default(now())
}

model Subscription {
  id        String   @id @default(cuid())

  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique

  plan      String
  status    String   @default("TRIAL")

  startDate DateTime @default(now())
  endDate   DateTime?

  transactionRef String?

  createdAt DateTime @default(now())
}

